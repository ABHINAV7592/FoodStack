@model List<Category>

<h2>Categories</h2>

<form asp-action="AddCategory" method="post">
    <input type="text" name="category_name" placeholder="Category Name" />
    <button class="btn btn-primary">Add</button>
</form>

<table class="table">
    <tr>
        <th>ID</th>
        <th>Name</th>
    </tr>

    @foreach (var c in Model)
    {
        <tr>
            <td>@c.category_id</td>
            <td>@c.category_name</td>
        </tr>
    }
</table>