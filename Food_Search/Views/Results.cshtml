@model List<Hotel>

@foreach (var h in Model)
{
    <div class="card m-2" style="width:18rem">

        <img src="@h.hotel_image" style="height:200px" />

        <div class="card-body">
            <h5>@h.hotel_name</h5>
            <p>@h.hotel_description</p>

            <form asp-controller="Review" asp-action="AddReview" method="post">
                <input type="hidden" name="hotel_id" value="@h.hotel_id" />

                <input type="number" name="rating" min="1" max="5" />

                <input type="text" name="comment" placeholder="Write review" />

                <button class="btn btn-primary">Submit</button>
            </form>
        </div>

    </div>
}